# Text LLM for Agent planning and final answers.
# Use openai for OpenAI-compatible GPT models.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# Alternative providers. Keep these empty unless you switch LLM_PROVIDER.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# Agent speed switches:
# AGENT_FAST_IMAGE_MODE=true means image questions skip the final text LLM answer
# after vision recognition and RAG/medicine retrieval. Faster, but less natural.
# AGENT_FAST_MODE=true means all non-danger Agent answers skip the final text LLM.
AGENT_FAST_IMAGE_MODE=false
AGENT_FAST_MODE=false
# Maximum wait for one model request before using the local safe fallback.
LLM_TIMEOUT_SECONDS=30

# Multimodal vision LLM. Do not commit real keys.
# Use an OpenAI-compatible /chat/completions vision endpoint from your provider.
VISION_LLM_PROVIDER=openai
VISION_LLM_API_KEY=
VISION_LLM_BASE_URL=https://api.openai.com/v1
VISION_LLM_MODEL=gpt-5.5
VISION_LLM_TIMEOUT=60
VISION_LLM_MAX_TOKENS=300
VISION_LLM_TEMPERATURE=0.1
VISION_LLM_IMAGE_DETAIL=auto

# Storage mode:
# - Leave DATABASE_URL and MYSQL_HOST empty to keep using backend/data/*.json locally.
# - Configure either DATABASE_URL or MYSQL_* to use cloud MySQL.
#
# DATABASE_URL example:
# DATABASE_URL=mysql+pymysql://rag_medical:change_this_password@127.0.0.1:3306/rag_medical?charset=utf8mb4
DATABASE_URL=

# MYSQL_* style is safer when the password contains special URL characters.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=rag_medical
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_medical
MYSQL_CHARSET=utf8mb4
MYSQL_JSON_TABLE=app_json_store
