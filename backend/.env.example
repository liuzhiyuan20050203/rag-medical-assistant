LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Multimodal vision LLM. Do not commit real keys.
# Use an OpenAI-compatible /chat/completions vision endpoint from your provider.
VISION_LLM_PROVIDER=custom
VISION_LLM_API_KEY=
VISION_LLM_BASE_URL=
VISION_LLM_MODEL=
VISION_LLM_TIMEOUT=60
VISION_LLM_MAX_TOKENS=900
VISION_LLM_TEMPERATURE=0.1
VISION_LLM_IMAGE_DETAIL=auto

# Semantic RAG embedding and retrieval.
# The first build downloads the model, then stores FAISS files under backend/data/rag_index/.
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_EMBEDDING_DEVICE=
RAG_EMBEDDING_BATCH_SIZE=32
RAG_MIN_SCORE=0.25
RAG_ANSWER_MIN_SCORE=0.28
RAG_CHUNK_MAX_CHARS=360
RAG_CHUNK_OVERLAP=80
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=lexical
RAG_RERANK_TOP_N=24
RAG_RERANK_WEIGHT=0.65
RAG_QUERY_PREFIX=
RAG_DOCUMENT_PREFIX=

# MySQL storage. Runtime data is stored in normalized MySQL tables.
# backend/data/*.json is only used as seed data by complete_mysql_database.py.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=rag_medical
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_medical
MYSQL_CHARSET=utf8mb4
