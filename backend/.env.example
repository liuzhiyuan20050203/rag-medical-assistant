LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Multimodal vision LLM. Do not commit real keys.
# Use an OpenAI-compatible /chat/completions vision endpoint from your provider.
VISION_LLM_PROVIDER=custom
VISION_LLM_API_KEY=
VISION_LLM_BASE_URL=
VISION_LLM_MODEL=
VISION_LLM_TIMEOUT=60
VISION_LLM_MAX_TOKENS=900
VISION_LLM_TEMPERATURE=0.1
VISION_LLM_IMAGE_DETAIL=auto

# Storage mode:
# - Leave DATABASE_URL and MYSQL_HOST empty to keep using backend/data/*.json locally.
# - Configure either DATABASE_URL or MYSQL_* to use cloud MySQL.
#
# DATABASE_URL example:
# DATABASE_URL=mysql+pymysql://rag_medical:change_this_password@127.0.0.1:3306/rag_medical?charset=utf8mb4
DATABASE_URL=

# MYSQL_* style is safer when the password contains special URL characters.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=rag_medical
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_medical
MYSQL_CHARSET=utf8mb4
MYSQL_JSON_TABLE=app_json_store
